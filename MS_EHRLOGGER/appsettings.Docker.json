{
  "Logging": {
    "LogLevel": {
      "Default":              "Information",
      "Microsoft.AspNetCore": "Warning",
      "MsEhrLogger":          "Debug"
    }
  },
  "AllowedHosts": "*",
  "Urls": "http://0.0.0.0:5003",

  "MongoDB": {
    "ConnectionString": "mongodb://ehrlogger_user:ehrlogger_pass@mongodb-medipass:27017/ehr_db?authSource=admin",
    "DatabaseName":     "ehr_db"
  },

  "RabbitMQ": {
    "Host":     "rabbitmq-medipass",
    "Port":     "5672",
    "Username": "medipass",
    "Password": "medipass_pass"
  },

  "Jaeger": {
    "Host":     "jaeger-medipass",
    "Port":     "6831",
    "Endpoint": "http://jaeger-medipass:14268/api/traces"
  },

  "EhrLogger": {
    "MaxRetries": 3
  }
}
