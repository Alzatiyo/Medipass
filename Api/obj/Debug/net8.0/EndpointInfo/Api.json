{
  "openapi": "3.0.1",
  "info": {
    "title": "MS-TrafficController — SkyWatch",
    "description": "Urban drone traffic control: flight plan authorization, no-fly zone validation and delivery proof registration.",
    "version": "v1"
  },
  "paths": {
    "/api/FlightPlan": {
      "get": {
        "tags": [
          "FlightPlan"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "post": {
        "tags": [
          "FlightPlan"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateFlightPlanRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateFlightPlanRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/CreateFlightPlanRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/FlightPlan/{id}": {
      "get": {
        "tags": [
          "FlightPlan"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/FlightPlan/{id}/delivery": {
      "patch": {
        "tags": [
          "FlightPlan"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterDeliveryRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterDeliveryRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterDeliveryRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/FlightPlan/{id}/status": {
      "patch": {
        "tags": [
          "FlightPlan"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateFlightStatusRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateFlightStatusRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateFlightStatusRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CreateFlightPlanRequest": {
        "type": "object",
        "properties": {
          "droneId": {
            "type": "string",
            "nullable": true
          },
          "originZone": {
            "type": "string",
            "nullable": true
          },
          "destinationZone": {
            "type": "string",
            "nullable": true
          },
          "altitudeMeters": {
            "type": "number",
            "format": "double"
          },
          "zoneType": {
            "$ref": "#/components/schemas/DroneZoneType"
          }
        },
        "additionalProperties": false
      },
      "DroneZoneType": {
        "enum": [
          0,
          1,
          2,
          3,
          4
        ],
        "type": "integer",
        "format": "int32"
      },
      "RegisterDeliveryRequest": {
        "type": "object",
        "properties": {
          "proofImageUrl": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "UpdateFlightStatusRequest": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      }
    }
  }
}